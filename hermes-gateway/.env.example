# Hermes Gateway 配置
# 复制为 .env 后修改

# 密钥（务必修改为随机字符串）
GATEWAY_SECRET_KEY=change-me-to-a-random-string

# 用户配置（JSON 数组格式，支持多用户）
# 密码使用 bcrypt 哈希
GATEWAY_USERS=[{"username":"admin","password":"$2b$12$LJ3m4ys3Lk..."}]

# 或单用户快速配置（二选一）
# GATEWAY_USERNAME=admin
# GATEWAY_PASSWORD=your-password-here

# Hermes 后端地址
HERMES_BASE_URL=http://127.0.0.1:9119

# 网关监听地址
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# 用户数据库路径（SQLite，不填默认 data/users.db）
GATEWAY_DB_PATH=data/users.db

# Cookie 安全设置（公网 HTTPS 部署建议设为 true）
GATEWAY_COOKIE_SECURE=false
